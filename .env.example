# ── FCTA Portal – Variables d'entorn ──────────────────────
# Copia aquest fitxer com a ".env" i ajusta els valors.
# MAI pujis el fitxer .env real al repositori git.

# Port del servidor (per defecte 3000)
PORT=3000

# Secret per signar els tokens JWT.
# Genera'n un amb: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=canvia_aquest_secret_per_un_de_aleatori_llarg

# Durada de la sessió admin (per defecte 8h)
JWT_EXPIRY=8h

# Contrassenyes inicials dels usuaris (opcionals; si no es defineixen s'usen els valors per defecte)
# Un cop creat l'usuari a la BD, canvia la contrasenya des del panell admin.
ADMIN_PASS=fcta2026
SEC_PASS=fcta$sec

# Entorn (development | production)
NODE_ENV=production
